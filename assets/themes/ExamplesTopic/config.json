{
    "version": "1.0",
    "name": "My Custom Theme",
    "description": "自定义主题模板 - 请修改此文件创建您自己的主题",
    "author": "Your Name",
    "createdAt": "2026-01-01",
    "styles": {
        "global": {
            "--bg-primary": "#1a1a2e",
            "--bg-secondary": "#16213e",
            "--bg-tertiary": "#0f3460",
            "--text-primary": "#ffffff",
            "--text-secondary": "#a0a0a0",
            "--accent-color": "#e94560",
            "--accent-color-rgb": "233, 69, 96",
            "--border-color": "#2a2a4a",
            "--font-family": "'Segoe UI', 'Microsoft YaHei', sans-serif",
            "--font-size-time": "8em",
            "--font-size-date": "1.5em",
            "--font-size-countdown": "10em",
            "--font-size-gaokao": "2em",
            "--border-radius": "8px",
            "--border-width": "1px",
            "--opacity-primary": "1",
            "--opacity-secondary": "0.8"
        },
        "elements": {
            "appContainer": {
                "background": "none",
                "backgroundColor": "var(--bg-primary)",
                "backgroundImage": null,
                "backgroundRepeat": "no-repeat",
                "backgroundSize": "cover",
                "backgroundPosition": "center"
            },
            "mainDisplay": {
                "background": "none",
                "backgroundColor": "transparent",
                "border": "none"
            },
            "timeSection": {
                "background": "none",
                "backgroundColor": "rgba(22, 33, 62, 0.9)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "var(--border-radius)",
                "padding": "20px 40px",
                "backdropFilter": "blur(10px)"
            },
            "currentTime": {
                "color": "var(--text-primary)",
                "fontSize": "var(--font-size-time)",
                "fontWeight": "300",
                "textAlign": "center"
            },
            "currentDate": {
                "color": "var(--text-secondary)",
                "fontSize": "var(--font-size-date)",
                "textAlign": "center",
                "marginTop": "10px"
            },
            "countdownSection": {
                "background": "none",
                "backgroundColor": "rgba(233, 69, 96, 0.15)",
                "border": "1px solid rgba(233, 69, 96, 0.3)",
                "borderRadius": "var(--border-radius)",
                "padding": "30px 50px"
            },
            "countdownTime": {
                "color": "var(--accent-color)",
                "fontSize": "var(--font-size-countdown)",
                "fontWeight": "400",
                "textAlign": "center"
            },
            "countdownLabel": {
                "color": "var(--text-secondary)",
                "fontSize": "1.5em",
                "textAlign": "center",
                "marginTop": "15px"
            },
            "gaokaoSection": {
                "background": "none",
                "backgroundColor": "rgba(22, 33, 62, 0.8)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "var(--border-radius)",
                "padding": "15px 30px"
            },
            "gaokaoCountdown": {
                "color": "var(--text-primary)",
                "fontSize": "var(--font-size-gaokao)",
                "textAlign": "center"
            },
            "controlBar": {
                "background": "rgba(22, 33, 62, 0.95)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "16px"
            },
            "controlBtn": {
                "background": "transparent",
                "border": "none",
                "borderRadius": "8px",
                "color": "var(--text-secondary)"
            },
            "countdownControlBtn": {
                "background": "rgba(15, 52, 96, 0.8)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "8px",
                "color": "var(--text-primary)"
            },
            "sidePanel": {
                "background": "rgba(26, 26, 46, 0.98)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "16px 0 0 16px"
            },
            "modal": {
                "background": "rgba(22, 33, 62, 0.95)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "12px"
            },
            "modalBtn": {
                "background": "var(--accent-color)",
                "border": "none",
                "borderRadius": "6px",
                "color": "#ffffff",
                "padding": "10px 20px"
            },
            "themeBtn": {
                "background": "rgba(42, 42, 74, 0.5)",
                "border": "1px solid var(--border-color)",
                "borderRadius": "8px"
            },
            "layoutPresetItem": {
                "background": "rgba(42, 42, 74, 0.5)",
                "border": "2px solid transparent",
                "borderRadius": "8px"
            },
            "customThemeItem": {
                "background": "rgba(42, 42, 74, 0.5)",
                "border": "1px solid transparent",
                "borderRadius": "6px"
            }
        },
        "buttons": {
            "personalizeBtn": {
                "icon": null
            },
            "scheduleBtn": {
                "icon": null
            },
            "settingsBtn": {
                "icon": null
            },
            "countdownBtn": {
                "icon": null
            },
            "fullscreenBtn": {
                "icon": null
            }
        },
        "animations": {
            "enable": true,
            "type": "fade",
            "duration": "300ms",
            "timingFunction": "ease"
        }
    }
}
